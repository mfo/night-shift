#!/usr/bin/env bash
# nightshift — tmux launcher that syncs worktrees with their PR status
#
# Usage:
#   nightshift attach [repo-path]    — create/attach tmux session from worktrees (idempotent)
#   nightshift refresh [repo-path]   — refresh PR status on all windows
#   nightshift status [repo-path]    — print status table to stdout
#   nightshift watch [repo-path]     — continuous refresh loop (every 2 min)
#   nightshift diagnose [pr-number]  — fetch CI logs and display diagnostic for a 🔴 PR
#   nightshift autofix [repo-path] [pr-number] — unblock CI: fix linters, fix specs (claude), retry system tests
#   nightshift brief [repo-path]   — morning brief: actions, changements overnight, suggestion
#
# Window naming convention:
#   🔨 branche                — no PR yet
#   ⏳ #123 slug              — CI running
#   🟢 #123 slug              — CI green, waiting review
#   🔴 #123 slug              — CI failed
#   💬 #123 slug (3)          — has review comments
#   ✅ #123 slug              — approved
#   🗑 #123 slug               — merged (worktree supprimable)
#   ⊘ #123 slug               — closed
#   ⛔ #123 slug              — changes requested
#
# Environment:
#   NIGHTSHIFT_REPO            — repo path (default: ~/dev/demarches-simplifiees.fr)
#   NIGHTSHIFT_SESSION         — tmux session name (default: nightshift)
#   NIGHTSHIFT_WATCH_INTERVAL  — refresh interval in seconds (default: 120)

set -euo pipefail
export LC_ALL=en_US.UTF-8

SESSION="${NIGHTSHIFT_SESSION:-nightshift}"
DEFAULT_REPO="${NIGHTSHIFT_REPO:-$HOME/dev/demarches-simplifiees.fr}"
WATCH_INTERVAL="${NIGHTSHIFT_WATCH_INTERVAL:-120}"
SELF="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
DEBUG="${NIGHTSHIFT_DEBUG:-0}"

debug() {
  [ "$DEBUG" = "1" ] && echo "  [debug] $*" >&2 || true
}

# Spinner: run a command in background, show spinner while waiting
# Usage: spin "message" command arg1 arg2 ...
# Output goes to $SPIN_LOG if set, otherwise /dev/null
spin() {
  local msg="$1"; shift
  local chars="⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"
  local log="${SPIN_LOG:-/dev/null}"

  "$@" > "$log" 2>&1 &
  local pid=$!
  local i=0

  while kill -0 "$pid" 2>/dev/null; do
    printf "\r  %s %s" "${chars:i%${#chars}:1}" "$msg"
    i=$((i + 1))
    sleep 0.1
  done

  wait "$pid" 2>/dev/null
  local rc=$?
  printf "\r  %s %s\n" "$([ $rc -eq 0 ] && echo "✓" || echo "✗")" "$msg"
  return $rc
}

# Cache for gh_repo (computed once)
_GH_REPO=""
_ERRORS=0

# ---------- cleanup ----------

trap 'kill 0 2>/dev/null || true' SIGTERM SIGINT

# ---------- helpers ----------

repo_path() {
  echo "${1:-$DEFAULT_REPO}"
}

# Resolve owner/repo once, cache it
gh_repo() {
  local rpath="$1"
  if [ -n "$_GH_REPO" ]; then
    echo "$_GH_REPO"
    return
  fi
  _GH_REPO=$(git -C "$rpath" remote get-url origin 2>/dev/null | sed 's|.*github.com[:/]||;s|\.git$||')
  echo "$_GH_REPO"
}

# Resolve PR number from branch name (handles fork contributions)
# Args: repo, branch
# Output: PR number or empty
resolve_pr_number() {
  local repo="$1" branch="$2"
  local pr_num
  debug "resolve_pr_number repo=$repo branch=$branch"
  # Try direct branch first
  pr_num=$(gh pr list --repo "$repo" --head "$branch" --state open --json number --jq '.[0].number' 2>/dev/null) || true
  debug "try --head '$branch' → '${pr_num:-empty}'"
  if [ -n "$pr_num" ]; then
    echo "$pr_num"
    return
  fi
  # Try with fork prefix (user:branch)
  local gh_user
  gh_user=$(gh api user --jq .login 2>/dev/null) || gh_user="mfo"
  debug "try --head '$gh_user:$branch'"
  pr_num=$(gh pr list --repo "$repo" --head "$gh_user:$branch" --state open --json number --jq '.[0].number' 2>/dev/null) || true
  debug "result → '${pr_num:-empty}'"
  echo "$pr_num"
}

slug() {
  echo "$1" | sed 's|^US/||;s|^fix/||;s|^feat/||;s|^tech/||' | cut -c1-30
}

# Parse git worktree list into "path|branch" lines (skip first = main)
# Handles ~ in paths and branches with slashes
# Outputs lines to stdout: /absolute/path|branch-name
list_worktrees() {
  local rpath="$1"
  local tmpfile
  tmpfile=$(mktemp)

  git -C "$rpath" worktree list | tail -n +2 > "$tmpfile"

  while IFS= read -r line; do
    local wt_path wt_branch
    wt_path=$(echo "$line" | awk '{print $1}')
    wt_path="${wt_path/#\~/$HOME}"
    wt_branch=$(echo "$line" | sed -n 's/.*\[\(.*\)\]/\1/p')
    [ -z "$wt_branch" ] && continue
    [ -d "$wt_path" ] || continue
    echo "${wt_path}|${wt_branch}"
  done < "$tmpfile"

  rm -f "$tmpfile"
}

# Fetch PR data in two passes:
#   1. Lightweight: all user PRs (open+merged+closed) for branch→PR mapping
#   2. Rich: open PRs only, with CI checks + reviews for detailed status
# Output: branch|number|state|ci|review_count|review_decision
fetch_all_prs() {
  local rpath="$1"
  local repo gh_user
  repo=$(gh_repo "$rpath")
  gh_user=$(gh api user --jq .login 2>/dev/null) || gh_user="mfo"

  # Pass 1: all user PRs (lightweight, fast)
  local all_prs
  all_prs=$(gh pr list \
    --repo "$repo" \
    --state all \
    --limit 200 \
    --json number,headRefName,state,author \
    --jq "[.[] | select(.author.login == \"$gh_user\")] | .[] | \"\(.headRefName)|\(.number)|\(.state)\"" 2>/dev/null) || {
      echo "nightshift: gh API failed (network? auth? rate limit?)" >&2
      return 1
    }

  # Pass 2: open PRs with CI + reviews (richer, only ~30-40 PRs)
  local rich_jq='.[] | "\(.headRefName)|\(.number)|\(.state)|\(
    if (.statusCheckRollup | length) == 0 then "none"
    elif (.statusCheckRollup | all(.conclusion == "SUCCESS")) then "green"
    elif (.statusCheckRollup | any(.status == "IN_PROGRESS" or .status == "QUEUED" or .status == "PENDING")) then "running"
    elif (.statusCheckRollup | any(.conclusion == "FAILURE" or .conclusion == "ERROR" or .conclusion == "TIMED_OUT")) then "red"
    else "unknown"
    end
  )|\([.reviews[] | select(.state == "COMMENTED" or .state == "CHANGES_REQUESTED" or .state == "APPROVED")] | length)|\(.reviewDecision // "")|\(.updatedAt)|\(
    [.reviews[] | select(.state == "APPROVED" or .state == "CHANGES_REQUESTED" or .state == "COMMENTED")] | last | .author.login // ""
  )"'

  local open_prs
  open_prs=$(gh pr list \
    --repo "$repo" \
    --state open \
    --limit 50 \
    --json number,headRefName,state,statusCheckRollup,reviewDecision,reviews,updatedAt \
    --jq "$rich_jq" 2>/dev/null) || open_prs=""

  # Merge: for each user PR, use rich data if available, else lightweight
  echo "$all_prs" | while IFS='|' read -r branch number state; do
    [ -z "$branch" ] && continue
    # Try to find rich version
    local rich_line
    rich_line=$(echo "$open_prs" | grep "^${branch}|" | head -1 || true)
    if [ -n "$rich_line" ]; then
      echo "$rich_line"
    else
      # Merged/closed: no CI or reviews needed
      echo "${branch}|${number}|${state}|none|0|"
    fi
  done
}

# Lookup a branch in the cached PR data
# Args: branch, pr_data (lines from fetch_all_prs)
# Returns: number|state|ci|review_count|review_decision or empty
lookup_pr() {
  local branch="$1"
  local pr_data="$2"

  echo "$pr_data" | grep "^${branch}|" | head -1 | cut -d'|' -f2- || true
}

# Build window name from branch + PR info
window_name() {
  local branch="$1"
  local info="$2"  # number|state|ci|review_count|review_decision
  local short
  short=$(slug "$branch")

  if [ -z "$info" ]; then
    echo "🔨 $short"
    return
  fi

  IFS='|' read -r num state ci review_count review_decision <<< "$info"

  case "$state" in
    MERGED) echo "🗑 #$num $short"; return ;;
    CLOSED) echo "⊘ #$num $short"; return ;;
  esac

  # CI red is always the most urgent signal
  if [ "$ci" = "red" ]; then
    echo "🔴 #$num $short"
    return
  fi

  if [ "$review_decision" = "CHANGES_REQUESTED" ]; then
    echo "⛔ #$num $short"
    return
  fi

  if [ "$review_decision" = "APPROVED" ]; then
    echo "✅ #$num $short"
    return
  fi

  if [ "${review_count:-0}" -gt 0 ] 2>/dev/null; then
    echo "💬 #$num $short ($review_count)"
    return
  fi

  case "$ci" in
    green)   echo "🟢 #$num $short" ;;
    running) echo "⏳ #$num $short" ;;
    *)       echo "◯ #$num $short" ;;
  esac
}

# ---------- commands ----------

cmd_attach() {
  local rpath
  rpath=$(repo_path "${1:-}")

  if ! command -v tmux &>/dev/null; then
    echo "error: tmux not installed" >&2
    return 1
  fi

  if ! [ -d "$rpath/.git" ] && ! [ -f "$rpath/.git" ]; then
    echo "error: $rpath is not a git repo" >&2
    return 1
  fi

  # If session exists, just attach — don't destroy
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    # Show teaser if last brief was > 4h ago
    local last_brief_file="$NIGHTSHIFT_DIR/last_brief"
    local last_ts=0 now_ts
    now_ts=$(date +%s)
    [ -f "$last_brief_file" ] && last_ts=$(cat "$last_brief_file")
    if [ $((now_ts - last_ts)) -gt 14400 ]; then
      local teaser_data
      teaser_data=$(fetch_all_prs "$rpath" 2>/dev/null) || true
      if [ -n "$teaser_data" ]; then
        local teaser
        teaser=$(brief_teaser "$rpath" "$teaser_data")
        [ -n "$teaser" ] && echo "$teaser"
      fi
    fi

    echo "nightshift: session exists, attaching (use 'refresh' to update)"
    if [ -n "${TMUX:-}" ]; then
      tmux switch-client -t "$SESSION"
    else
      tmux attach -t "$SESSION"
    fi
    return
  fi

  # Batch fetch all PRs (1 API call)
  echo "  fetching PRs ..."
  local pr_data
  pr_data=$(fetch_all_prs "$rpath") || {
    echo "warning: could not fetch PRs (network? auth?), continuing without status" >&2
    pr_data=""
  }

  # Build session from worktrees
  local first=true
  local main_path
  main_path=$(git -C "$rpath" worktree list | head -1 | awk '{print $1}')
  main_path="${main_path/#\~/$HOME}"

  # Main repo as first window
  tmux new-session -d -s "$SESSION" -n "📦 main" -c "$main_path"
  tmux set-option -t "$SESSION" allow-rename off
  first=false

  while IFS='|' read -r wt_path wt_branch; do
    [ -n "$wt_path" ] || continue

    local info
    info=$(lookup_pr "$wt_branch" "$pr_data")
    local name
    name=$(window_name "$wt_branch" "$info")

    tmux new-window -t "$SESSION" -n "$name" -c "$wt_path"
    # Store worktree metadata in tmux user options
    local win_idx
    win_idx=$(tmux list-windows -t "$SESSION" -F '#{window_index}' | tail -1)
    tmux set-option -t "$SESSION:$win_idx" @worktree_path "$wt_path"
    tmux set-option -t "$SESSION:$win_idx" @branch "$wt_branch"

    # Auto-diagnose if CI is red
    if [ -n "$info" ]; then
      local _num _state _ci
      IFS='|' read -r _num _state _ci _ _ <<< "$info"
      if [ "$_ci" = "red" ] && [ "$_state" = "OPEN" ]; then
        tmux send-keys -t "$SESSION:$win_idx" "$SELF autofix '' $_num" Enter
      fi
    fi

    echo "  $name"
  done < <(list_worktrees "$rpath")

  local win_count
  win_count=$(tmux list-windows -t "$SESSION" | wc -l | tr -d ' ')
  echo ""
  echo "nightshift: $win_count windows ready"

  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$SESSION"
  else
    tmux attach -t "$SESSION"
  fi
}

cmd_refresh() {
  local rpath
  rpath=$(repo_path "${1:-}")
  local target_session="${2:-$SESSION}"

  # Batch fetch all PRs (1 API call)
  local pr_data
  pr_data=$(fetch_all_prs "$rpath") || {
    echo "nightshift: refresh failed (network? auth?)" >&2
    return 1
  }

  local changes=0

  while IFS=$'\t' read -r window_index current_name; do
    # Skip main window
    [[ "$current_name" == *"main"* ]] && continue

    # Read branch from stored tmux user option
    local branch
    branch=$(tmux show-option -t "$target_session:$window_index" -v @branch 2>/dev/null) || continue
    [ -z "$branch" ] && continue

    local info
    info=$(lookup_pr "$branch" "$pr_data")
    local new_name
    new_name=$(window_name "$branch" "$info")

    if [ "$new_name" != "$current_name" ]; then
      tmux rename-window -t "$target_session:$window_index" "$new_name"
      echo "  $current_name → $new_name"
      changes=$((changes + 1))

      # Auto-diagnose on transition to 🔴
      if [[ "$new_name" == 🔴* ]] && [[ "$current_name" != 🔴* ]]; then
        local pr_num
        pr_num=$(echo "$new_name" | grep -o '#[0-9]*' | tr -d '#' || true)
        if [ -n "$pr_num" ]; then
          tmux send-keys -t "$target_session:$window_index" "$SELF autofix '' $pr_num" Enter
        fi
      fi
    fi
  done < <(tmux list-windows -t "$target_session" -F "#{window_index}	#{window_name}")

  if [ "$changes" -eq 0 ]; then
    echo "nightshift: no changes"
  else
    echo "nightshift: $changes windows updated"
  fi

  # Sync: add new worktrees not yet in tmux
  local existing_branches
  existing_branches=$(tmux list-windows -t "$target_session" -F '' 2>/dev/null | while read -r idx; do
    tmux show-option -t "$target_session:$idx" -v @branch 2>/dev/null
  done)

  while IFS='|' read -r wt_path wt_branch; do
    [ -n "$wt_path" ] || continue
    if ! echo "$existing_branches" | grep -qx "$wt_branch"; then
      local info
      info=$(lookup_pr "$wt_branch" "$pr_data")
      local name
      name=$(window_name "$wt_branch" "$info")
      tmux new-window -t "$target_session" -n "$name" -c "$wt_path"
      local win_idx
      win_idx=$(tmux list-windows -t "$target_session" -F '#{window_index}' | tail -1)
      tmux set-option -t "$target_session:$win_idx" @worktree_path "$wt_path"
      tmux set-option -t "$target_session:$win_idx" @branch "$wt_branch"
      echo "  + $name (new worktree)"
    fi
  done < <(list_worktrees "$rpath")
}

cmd_status() {
  local rpath
  rpath=$(repo_path "${1:-}")

  echo "  fetching PRs ..."
  local pr_data
  pr_data=$(fetch_all_prs "$rpath") || {
    echo "error: could not fetch PRs" >&2
    return 1
  }

  echo ""
  while IFS='|' read -r wt_path wt_branch; do
    [ -n "$wt_path" ] || continue
    local info
    info=$(lookup_pr "$wt_branch" "$pr_data")
    local name
    name=$(window_name "$wt_branch" "$info")
    echo "  $name"
  done < <(list_worktrees "$rpath")
  echo ""
}

# Strip ANSI color codes from input
strip_ansi() {
  sed 's/\x1b\[[0-9;]*m//g'
}

cmd_diagnose() {
  local rpath
  rpath=$(repo_path "${1:-}")
  local repo
  repo=$(gh_repo "$rpath")

  # Resolve PR number: argument, or current git branch
  local pr_number="$2"
  if [ -z "$pr_number" ]; then
    local branch
    branch=$(git branch --show-current 2>/dev/null) || true
    debug "diagnose: git branch → '${branch:-empty}'"
    if [ -z "$branch" ]; then
      echo "error: could not determine branch. Pass PR number: nightshift diagnose <pr-number>" >&2
      return 1
    fi
    pr_number=$(resolve_pr_number "$repo" "$branch")
    if [ -z "$pr_number" ]; then
      echo "error: no open PR found for branch '$branch'" >&2
      return 1
    fi
  fi

  echo "── CI DIAGNOSTIC — PR #$pr_number ──────────────────────"
  echo ""

  # Get the latest CI run
  local run_id
  run_id=$(gh pr checks "$pr_number" --repo "$repo" --json link --jq '.[0].link' 2>/dev/null \
    | grep -o 'runs/[0-9]*' | head -1 | cut -d/ -f2) || true

  if [ -z "$run_id" ]; then
    echo "  no CI run found"
    return
  fi

  # Get all failed jobs
  local failed_jobs
  failed_jobs=$(gh api "repos/$repo/actions/runs/$run_id/jobs" \
    --jq '.jobs[] | select(.conclusion == "failure") | "\(.id)|\(.name)"' 2>/dev/null) || true

  if [ -z "$failed_jobs" ]; then
    echo "  ✅ no failed jobs"
    return
  fi

  echo "$failed_jobs" | while IFS='|' read -r job_id job_name; do
    [ -z "$job_id" ] && continue

    # Categorize the job
    local category action
    case "$job_name" in
      *CodeQL*|*codeql*)
        category="🔒 SECURITY"
        action="review manuelle requise"
        ;;
      *System*|*system*)
        category="🧪 SYSTEM TEST"
        action="retry recommandé: gh run rerun --job $job_id"
        ;;
      *Unit*|*unit*)
        category="🧪 UNIT TEST"
        action="specs à fixer"
        ;;
      *Lint*|*lint*)
        category="🧹 LINTER"
        action="autofix dispo"
        ;;
      *)
        category="❓ OTHER"
        action="voir logs"
        ;;
    esac

    echo "  $category — $job_name"
    echo "  → $action"

    # Fetch relevant log lines
    local logs
    logs=$(gh api "repos/$repo/actions/jobs/$job_id/logs" 2>/dev/null) || {
      echo "  ⚠ could not fetch logs"
      echo ""
      continue
    }

    case "$job_name" in
      *Lint*|*lint*)
        # Show offense lines + summary
        local offenses
        offenses=$(echo "$logs" | strip_ansi | grep -E "(\.rb:[0-9]+|\.erb:[0-9]+|\.haml:[0-9]+).*[CWEF]:" | sed 's/^.*Z /  /' | head -10)
        local summary
        summary=$(echo "$logs" | strip_ansi | grep -E "offenses? detected|autocorrectable" | sed 's/^.*Z /  /' | tail -1)
        if [ -n "$offenses" ]; then
          echo "$offenses"
        fi
        if [ -n "$summary" ]; then
          echo "$summary"
        fi
        # Show fix commands
        echo ""
        echo "  FIX: bundle exec rubocop -a"
        echo "       bun lint:herb --fix"
        echo "       bundle exec rake lint:apostrophe:fix"
        echo "       bundle exec rake lint:yaml_newline:fix"
        ;;

      *Unit*|*unit*|*System*|*system*)
        # Show failed spec file:line + description
        local failures
        failures=$(echo "$logs" | strip_ansi | grep -E "rspec \./spec/" | sed 's/^.*rspec /  rspec /' | head -10 || true)
        local summary
        summary=$(echo "$logs" | strip_ansi | grep -E "[0-9]+ examples?, [0-9]+ failures?" | sed 's/^.*Z /  /' | tail -1 || true)
        local fail_descriptions
        fail_descriptions=$(echo "$logs" | strip_ansi | grep -E "(Failure/Error:|expected:.*got:)" | sed 's/^.*Z\s*/  /' | head -10 || true)

        if [ -n "$failures" ]; then
          echo "$failures"
        fi
        if [ -n "$fail_descriptions" ]; then
          echo "$fail_descriptions"
        fi
        if [ -n "$summary" ]; then
          echo "$summary"
        fi
        ;;

      *CodeQL*|*codeql*)
        echo "  ⚠ CodeQL findings — check GitHub Security tab"
        ;;
    esac

    echo ""
  done

  # Suggest autofix if linter-only
  if [ -n "$run_id" ] && ci_has_linter_failure "$repo" "$run_id" 2>/dev/null; then
    echo "  💡 Linter failures detected — run: nightshift autofix"
    echo ""
  fi
}

# Check if any failed job is a linter
# Returns 0 if at least one linter failure, 1 otherwise
ci_has_linter_failure() {
  local repo="$1" run_id="$2"

  local failed_jobs
  failed_jobs=$(gh api "repos/$repo/actions/runs/$run_id/jobs" \
    --jq '.jobs[] | select(.conclusion == "failure") | .name' 2>/dev/null) || return 1

  [ -z "$failed_jobs" ] && return 1

  while IFS= read -r job_name; do
    case "$job_name" in
      *Lint*|*lint*) return 0 ;;
    esac
  done <<< "$failed_jobs"

  return 1
}

# Extract failed spec lines from CI logs
# Args: repo, run_id
# Output: rspec ./spec/... lines (one per line)
extract_failed_specs() {
  local repo="$1" run_id="$2"

  local failed_jobs
  failed_jobs=$(gh api "repos/$repo/actions/runs/$run_id/jobs" \
    --jq '.jobs[] | select(.conclusion == "failure") | "\(.id)|\(.name)"' 2>/dev/null) || return 1

  echo "$failed_jobs" | while IFS='|' read -r job_id job_name; do
    case "$job_name" in
      *Unit*|*unit*|*System*|*system*)
        local logs
        logs=$(gh api "repos/$repo/actions/jobs/$job_id/logs" 2>/dev/null) || continue
        echo "$logs" | strip_ansi | grep -oE "rspec \./spec/[^ ]+" || true
        ;;
    esac
  done
}

cmd_autofix() {
  local rpath
  rpath=$(repo_path "${1:-}")
  local repo
  repo=$(gh_repo "$rpath")

  local pr_number="${2:-}"
  local wt_path branch

  wt_path=$(pwd)
  branch=$(git -C "$wt_path" branch --show-current 2>/dev/null) || true
  debug "cmd_autofix wt_path=$wt_path branch='${branch:-empty}'"

  if [ -z "$pr_number" ]; then
    if [ -z "$branch" ]; then
      echo "error: could not determine branch" >&2
      return 1
    fi
    pr_number=$(resolve_pr_number "$repo" "$branch")
    if [ -z "$pr_number" ]; then
      echo "error: no open PR for branch '$branch'" >&2
      return 1
    fi
  fi

  # Status dashboard
  local st_linter="⚫" st_unit="⚫" st_codeql="⚫" st_system="⚫"

  dashboard() {
    echo ""
    echo "  $st_linter linter   $st_unit unit   $st_codeql codeql   $st_system system"
    echo "  ──────────────────────────────────────────────"
  }

  echo "── AUTOFIX — PR #$pr_number ──────────────────────"

  # Circuit breaker: max 2 autofix per PR per hour (via tmux options)
  if [ -n "${TMUX:-}" ]; then
    local count last_ts now
    count=$(tmux show-option -v @autofix_count 2>/dev/null) || count=0
    last_ts=$(tmux show-option -v @autofix_ts 2>/dev/null) || last_ts=0
    now=$(date +%s)
    if [ $((now - last_ts)) -gt 3600 ]; then
      count=0
    fi
    if [ "$count" -ge 2 ] && [ "$DEBUG" != "1" ]; then
      echo "  ⛔ circuit breaker: 2 autofix attempts in the last hour, skipping"
      return 1
    fi
    [ "$count" -ge 2 ] && debug "circuit breaker bypassed (debug mode)"
  fi

  # Get latest CI run + categorize failures
  local run_id
  run_id=$(gh pr checks "$pr_number" --repo "$repo" --json link --jq '.[0].link' 2>/dev/null \
    | grep -o 'runs/[0-9]*' | head -1 | cut -d/ -f2) || true

  if [ -z "$run_id" ]; then
    echo "  no CI run found"
    return 1
  fi

  # Categorize failures
  local has_linter=false has_specs=false
  local failed_specs="" system_test_jobs=""

  ci_has_linter_failure "$repo" "$run_id" && has_linter=true
  failed_specs=$(extract_failed_specs "$repo" "$run_id")
  [ -n "$failed_specs" ] && has_specs=true

  # Detect system test failures for retry
  system_test_jobs=$(gh api "repos/$repo/actions/runs/$run_id/jobs" \
    --jq '.jobs[] | select(.conclusion == "failure") | select(.name | test("System|system")) | "\(.id)|\(.name)"' 2>/dev/null) || true

  # Detect CodeQL failures
  local has_codeql=false
  gh api "repos/$repo/actions/runs/$run_id/jobs" \
    --jq '.jobs[] | select(.conclusion == "failure") | .name' 2>/dev/null \
    | grep -qi "codeql" && has_codeql=true

  if ! $has_linter && ! $has_specs && [ -z "$system_test_jobs" ] && ! $has_codeql; then
    echo "  ✋ nothing to autofix"
    echo "  use 'nightshift diagnose' for full diagnostic"
    return 1
  fi

  # Init dashboard
  $has_linter && st_linter="🔴" || st_linter="⚫"
  $has_specs && st_unit="🔴" || st_unit="⚫"
  $has_codeql && st_codeql="🔴" || st_codeql="⚫"
  [ -n "$system_test_jobs" ] && st_system="🔴" || st_system="⚫"

  dashboard

  cd "$wt_path"
  local _logdir="$wt_path/tmp"
  mkdir -p "$_logdir"

  # ── Step 1: System test retry (fast API call) ──

  if [ -n "$system_test_jobs" ]; then
    echo ""
    echo "  → retrying system tests ..."
    local retry_count
    retry_count=$(tmux show-option -v @retry_count 2>/dev/null) || retry_count=0

    if [ "$retry_count" -ge 1 ]; then
      echo "  ⛔ already retried once — likely a real failure"
    else
      echo "$system_test_jobs" | while IFS='|' read -r job_id job_name; do
        echo "  → gh run rerun --job $job_id ($job_name)"
        gh run rerun --repo "$repo" --job "$job_id" 2>&1 || true
      done
      [ -n "${TMUX:-}" ] && tmux set-option @retry_count 1
      st_system="⏳"
    fi
    dashboard
  fi

  if $has_codeql; then
    echo ""
    echo "  → 🔒 CodeQL findings — requires manual review on GitHub Security tab"
  fi

  # ── Step 2: Specs fix (claude -p) ──

  if $has_specs; then
    echo ""
    echo "  failed specs:"
    echo "$failed_specs" | sed 's/^/    /'
    echo ""

    local claude_prompt="CI detected failing specs in this project. Here are the failed specs:

$failed_specs

Investigate each failure: read the spec file, read the implementation code, understand why it fails, and fix the code (not the spec, unless the spec itself is wrong). Run the failing specs to verify your fix. Do NOT commit. Do NOT push."

    echo "  → claude prompt:"
    echo "$claude_prompt" | sed 's/^/    /'
    echo ""
    local claude_cmd="claude -p \"...\" --allowedTools \"Read,Edit,Glob,Grep,Bash(bundle exec rspec:*),Bash(git diff:*),Bash(git status)\" --output-format stream-json --verbose --max-turns 20"
    echo "  → $claude_cmd"
    echo "  → logs: $_logdir/claude.log"
    echo ""

    SPIN_LOG="$_logdir/claude.log" spin "claude fixing specs ..." \
      claude -p "$claude_prompt" \
        --allowedTools "Read,Edit,Glob,Grep,Bash(bundle exec rspec:*),Bash(git diff:*),Bash(git status)" \
        --output-format stream-json --verbose --max-turns 20 \
      || true

    st_unit="🟡"
    dashboard
  fi

  # ── Step 3: Linters — last, cleans up what claude may have broken ──

  if $has_linter; then
    echo ""
    echo "  → fixing linters ..."

    local rb_files
    rb_files=$(git -C "$wt_path" diff main --name-only | grep '\.rb$' || true)
    if [ -n "$rb_files" ]; then
      local rb_count
      rb_count=$(echo "$rb_files" | wc -l | tr -d ' ')
      SPIN_LOG="$_logdir/rubocop.log" spin "rubocop -A ($rb_count files)" bash -c "echo '$rb_files' | xargs bundle exec rubocop -A" || true
    fi

    SPIN_LOG="$_logdir/herb.log" spin "bun lint:herb --fix" bun lint:herb --fix || true
    SPIN_LOG="$_logdir/apostrophe.log" spin "rake lint:apostrophe:fix" bundle exec rake lint:apostrophe:fix || true
    SPIN_LOG="$_logdir/yaml.log" spin "rake lint:yaml_newline:fix" bundle exec rake lint:yaml_newline:fix || true

    st_linter="🟡"
    dashboard
  fi

  echo ""
  echo "  → verifying ..."

  if $has_linter; then
    local rb_files_check
    rb_files_check=$(git -C "$wt_path" diff main --name-only | grep '\.rb$' || true)
    if [ -n "$rb_files_check" ]; then
      SPIN_LOG="$_logdir/verify-rubocop.log" spin "verifying rubocop" bash -c "echo '$rb_files_check' | xargs bundle exec rubocop" || true
      local lint_summary
      lint_summary=$(tail -1 "$_logdir/verify-rubocop.log")
      if echo "$lint_summary" | grep -q "no offenses"; then
        st_linter="🟢"
        echo "  rubocop: $lint_summary"
      else
        st_linter="🔴"
        echo "  rubocop: $lint_summary"
        grep -E "^[^ ].*:[0-9]+:" "$_logdir/verify-rubocop.log" | head -5 | sed 's/^/    /'
      fi
    fi
  fi

  if $has_specs; then
    local spec_files
    spec_files=$(echo "$failed_specs" | sed 's/^rspec //' | tr '\n' ' ')
    SPIN_LOG="$_logdir/verify-rspec.log" spin "verifying rspec" bundle exec rspec $spec_files || true
    local spec_summary
    spec_summary=$(grep -E "[0-9]+ examples?" "$_logdir/verify-rspec.log" | tail -1)
    if echo "$spec_summary" | grep -q "0 failures"; then
      st_unit="🟢"
      echo "  specs: $spec_summary"
    else
      st_unit="🔴"
      echo "  specs: $spec_summary"
      grep -E "(Failure/Error:|rspec \./spec/)" "$_logdir/verify-rspec.log" | head -10 | sed 's/^/    /'
    fi
  fi

  if [ -n "$system_test_jobs" ]; then
    local run_url="https://github.com/$repo/actions/runs/$run_id"
    echo "  system tests: $run_url"
  fi

  dashboard

  echo ""
  local changed_files
  changed_files=$(git -C "$wt_path" diff --name-only)
  if [ -n "$changed_files" ]; then
    local file_count
    file_count=$(echo "$changed_files" | wc -l | tr -d ' ')
    echo "  $file_count file(s) modified:"
    echo ""
    git -C "$wt_path" diff --color --stat
    echo ""
    git -C "$wt_path" diff --color
    echo ""
    echo "  next: git add -u && git commit && git push mfo HEAD"
  else
    echo "  ✅ done (no local changes)"
  fi

  # Update circuit breaker
  if [ -n "${TMUX:-}" ]; then
    local new_count=$((count + 1))
    tmux set-option @autofix_count "$new_count"
    tmux set-option @autofix_ts "$(date +%s)"
  fi
}

# Convert ISO timestamp to relative age (e.g., "il y a 3h", "hier", "3 jours")
relative_age() {
  local ts="$1"
  [ -z "$ts" ] && echo "" && return
  local now epoch delta
  now=$(date +%s)
  epoch=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$ts" +%s 2>/dev/null) || {
    # Try alternate format
    epoch=$(date -j -f "%Y-%m-%dT%T" "${ts%%Z*}" +%s 2>/dev/null) || { echo ""; return; }
  }
  delta=$((now - epoch))

  if [ "$delta" -lt 60 ]; then
    echo "à l'instant"
  elif [ "$delta" -lt 3600 ]; then
    echo "il y a $((delta / 60))min"
  elif [ "$delta" -lt 86400 ]; then
    echo "il y a $((delta / 3600))h"
  elif [ "$delta" -lt 172800 ]; then
    echo "hier"
  else
    echo "il y a $((delta / 86400)) jours"
  fi
}

# Get emoji for PR state (same logic as window_name but returns just the emoji)
pr_emoji() {
  local state="$1" ci="$2" review_decision="$3" review_count="$4"
  case "$state" in
    MERGED) echo "🗑"; return ;;
    CLOSED) echo "⊘"; return ;;
  esac
  if [ "$ci" = "red" ]; then echo "🔴"; return; fi
  if [ "$review_decision" = "CHANGES_REQUESTED" ]; then echo "⛔"; return; fi
  if [ "$review_decision" = "APPROVED" ]; then echo "✅"; return; fi
  if [ "${review_count:-0}" -gt 0 ] 2>/dev/null; then echo "💬"; return; fi
  case "$ci" in
    green)   echo "🟢" ;;
    running) echo "⏳" ;;
    *)       echo "◯" ;;
  esac
}

NIGHTSHIFT_DIR="$HOME/.nightshift"

cmd_brief() {
  local rpath
  rpath=$(repo_path "${1:-}")

  local pr_data
  pr_data=$(fetch_all_prs "$rpath") || {
    echo "error: could not fetch PRs" >&2
    return 1
  }

  # Load previous snapshot for transition detection
  mkdir -p "$NIGHTSHIFT_DIR"
  local snapshot_file="$NIGHTSHIFT_DIR/state_snapshot"
  local prev_snapshot=""
  [ -f "$snapshot_file" ] && prev_snapshot=$(cat "$snapshot_file")

  # Load last brief timestamp
  local last_brief_file="$NIGHTSHIFT_DIR/last_brief"
  local last_brief_ts=0
  [ -f "$last_brief_file" ] && last_brief_ts=$(cat "$last_brief_file")

  local now
  now=$(date +%s)

  echo "── morning brief ────────────────────────── $(date '+%d %b, %H:%M')"
  echo ""

  # Collect open PRs with worktrees
  local actions="" changes="" summary_approved=0 summary_green=0 summary_red=0 summary_requested=0 summary_comments=0 summary_running=0 total_open=0

  while IFS='|' read -r wt_path wt_branch; do
    [ -n "$wt_path" ] || continue
    local info
    info=$(lookup_pr "$wt_branch" "$pr_data")
    [ -z "$info" ] && continue

    local num state ci review_count review_decision updated_at reviewer
    IFS='|' read -r num state ci review_count review_decision updated_at reviewer <<< "$info"

    [ "$state" = "MERGED" ] || [ "$state" = "CLOSED" ] && continue
    total_open=$((total_open + 1))

    local short
    short=$(slug "$wt_branch")
    local emoji
    emoji=$(pr_emoji "$state" "$ci" "$review_decision" "$review_count")
    local age
    age=$(relative_age "$updated_at")

    # Count for summary
    case "$emoji" in
      ✅) summary_approved=$((summary_approved + 1)) ;;
      🟢) summary_green=$((summary_green + 1)) ;;
      🔴) summary_red=$((summary_red + 1)) ;;
      ⛔) summary_requested=$((summary_requested + 1)) ;;
      💬) summary_comments=$((summary_comments + 1)) ;;
      ⏳) summary_running=$((summary_running + 1)) ;;
    esac

    # Actions: PRs that need human action
    case "$emoji" in
      ✅) actions="${actions}  ✅ #${num} ${short}$(printf '%*s' $((30 - ${#short})) '')approved ${age} → merger\n" ;;
      ⛔) actions="${actions}  ⛔ #${num} ${short}$(printf '%*s' $((30 - ${#short})) '')changes requested ${age}\n" ;;
      💬) actions="${actions}  💬 #${num} ${short} (${review_count})$(printf '%*s' $((28 - ${#short})) '')${review_count} comments ${age}\n" ;;
    esac

    # Detect transitions since last brief
    local current_key="${num}|${emoji}"
    if [ -n "$prev_snapshot" ]; then
      local prev_emoji
      prev_emoji=$(echo "$prev_snapshot" | grep "^${num}|" | cut -d'|' -f2)
      if [ -n "$prev_emoji" ] && [ "$prev_emoji" != "$emoji" ]; then
        local reviewer_info=""
        [ -n "$reviewer" ] && reviewer_info=" par $reviewer"
        changes="${changes}  ${prev_emoji}→${emoji} #${num} ${short}${reviewer_info}\n"
      fi
    fi

    # Save to new snapshot
    echo "${current_key}" >> "$snapshot_file.new"
  done < <(list_worktrees "$rpath")

  # Also check PRs without worktrees (in case a review came in)
  echo "$pr_data" | while IFS='|' read -r branch num state ci review_count review_decision updated_at reviewer; do
    [ "$state" = "OPEN" ] || continue
    local emoji
    emoji=$(pr_emoji "$state" "$ci" "$review_decision" "$review_count")
    echo "${num}|${emoji}" >> "$snapshot_file.new"
  done

  # Print sections
  local has_content=false

  if [ -n "$actions" ]; then
    echo "  ACTION REQUISE"
    echo ""
    printf "$actions"
    echo ""
    has_content=true
  fi

  if [ -n "$changes" ]; then
    echo "  CHANGEMENTS"
    echo ""
    printf "$changes"
    echo ""
    has_content=true
  fi

  # Summary line
  local summary_parts=""
  [ "$summary_approved" -gt 0 ] && summary_parts="${summary_parts} ${summary_approved} ✅"
  [ "$summary_green" -gt 0 ] && summary_parts="${summary_parts} ${summary_green} 🟢"
  [ "$summary_red" -gt 0 ] && summary_parts="${summary_parts} ${summary_red} 🔴"
  [ "$summary_requested" -gt 0 ] && summary_parts="${summary_parts} ${summary_requested} ⛔"
  [ "$summary_comments" -gt 0 ] && summary_parts="${summary_parts} ${summary_comments} 💬"
  [ "$summary_running" -gt 0 ] && summary_parts="${summary_parts} ${summary_running} ⏳"

  echo "  ${total_open} PRs ouvertes :${summary_parts}"
  echo ""

  # Suggestion
  if [ "$summary_approved" -gt 0 ]; then
    echo "  → commence par : merger les PRs approved"
  elif [ "$summary_requested" -gt 0 ]; then
    echo "  → commence par : adresser les changes requested"
  elif [ "$summary_comments" -gt 0 ]; then
    echo "  → commence par : lire les review comments"
  elif [ "$summary_red" -gt 0 ]; then
    echo "  → commence par : fixer les CI rouges"
  else
    echo "  → rien d'urgent, continue le dev en cours"
  fi

  echo "──────────────────────────────────────────────────────────"

  # Update snapshot + timestamp
  [ -f "$snapshot_file.new" ] && mv "$snapshot_file.new" "$snapshot_file"
  echo "$now" > "$last_brief_file"
}

# Teaser for attach (1-liner if actions pending)
brief_teaser() {
  local rpath="$1"
  local pr_data="$2"

  local n_approved=0 n_requested=0 n_comments=0

  while IFS='|' read -r branch num state ci review_count review_decision _rest; do
    [ "$state" = "OPEN" ] || continue
    if [ "$review_decision" = "APPROVED" ]; then
      n_approved=$((n_approved + 1))
    elif [ "$review_decision" = "CHANGES_REQUESTED" ]; then
      n_requested=$((n_requested + 1))
    elif [ "${review_count:-0}" -gt 0 ] 2>/dev/null; then
      n_comments=$((n_comments + 1))
    fi
  done <<< "$pr_data"

  local total=$((n_approved + n_requested + n_comments))
  [ "$total" -eq 0 ] && return

  local parts=""
  [ "$n_approved" -gt 0 ] && parts="${parts}${n_approved} à merger, "
  [ "$n_requested" -gt 0 ] && parts="${parts}${n_requested} changes requested, "
  [ "$n_comments" -gt 0 ] && parts="${parts}${n_comments} comments, "
  parts="${parts%, }"

  echo "  ☀ ${total} actions: ${parts} — \`nightshift brief\`"
}

cmd_watch() {
  local rpath
  rpath=$(repo_path "${1:-}")

  echo "nightshift: watching every ${WATCH_INTERVAL}s (ctrl-c to stop)"
  while true; do
    cmd_refresh "$rpath" 2>&1 | sed "s/^/  [$(date +%H:%M)] /"
    sleep "$WATCH_INTERVAL"
  done
}

# ---------- main ----------

cmd="${1:-attach}"
shift 2>/dev/null || true

case "$cmd" in
  attach)  cmd_attach "$@" ;;
  refresh) cmd_refresh "$@" ;;
  status)  cmd_status "$@" ;;
  watch)    cmd_watch "$@" ;;
  diagnose) cmd_diagnose "${1:-}" "${2:-}" ;;
  autofix)  cmd_autofix "${1:-}" "${2:-}" ;;
  brief)   cmd_brief "${1:-}" ;;
  *)
    echo "Usage: nightshift {attach|refresh|status|watch|diagnose|autofix|brief} [repo-path] [pr-number]"
    exit 1
    ;;
esac
