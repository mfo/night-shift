---
title: Reconciler — Boucle 120s
---
flowchart TD
    watch([watch 120s])
    watch --> pr_recon
    watch --> health
    watch --> scheduling

    subgraph pr_recon ["PR Reconciliation"]
        direction LR
        fetch([fetch PRs]) --> upsert([upsert\ndetect state change]) --> transition([on_transition\nautofix / merge / cleanup])
    end

    subgraph health ["Health check (items running + pr_open)"]
        direction LR
        pr_open([pr_open\nPR merged? -> done\nPR closed? -> skipped])
        running([running\nprocess dead? -> retry ou skip])
        orphans([cleanup orphan worktrees\nauto/ sans item actif])
        pr_open --> running --> orphans
    end

    subgraph scheduling ["Scheduling (par skill)"]
        direction TB
        for_skill([pour chaque skill\nordre .nightshift.yml])
        gate1{active_for_skill?\n1 PR max par skill}
        gate2{backend.concurrency\nex: local=1 frontier=4}
        claim([claim_next\npriority DESC])
        launch([launch_skill\nworktree + tmux + skill-run])

        for_skill --> gate1
        gate1 -->|deja actif| wait1([attend merge/close])
        gate1 -->|libre| gate2
        gate2 -->|backend plein| wait2([attend prochain cycle])
        gate2 -->|slot libre| claim --> launch
    end

    scheduling --> watch

    style watch fill:#f3e5f5,stroke:#6a1b9a
    style pr_recon fill:#e3f2fd,stroke:#1565c0
    style health fill:#fff3e0,stroke:#e65100
    style scheduling fill:#e8f5e9,stroke:#2e7d32
    style gate1 fill:#ffebee,stroke:#c62828
    style gate2 fill:#ffebee,stroke:#c62828
    style wait1 fill:#eeeeee,stroke:#757575
    style wait2 fill:#eeeeee,stroke:#757575
