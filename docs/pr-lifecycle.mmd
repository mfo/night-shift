---
title: PR Lifecycle
---
flowchart LR
    draft([◯ Draft])
    ci_running([⏳ CiRunning])
    ci_green([🟢 CiGreen])
    approved([✅ Approved])
    auto_merging([🔀 AutoMerging])
    merged([🗑 Merged])
    deployed([🚀 Deployed])
    ci_red([🔴 CiRed])
    has_comments([💬 HasComments])
    changes_requested([⛔ ChangesRequested])
    closed([⊘ Closed])

    draft --> ci_running
    ci_running --> ci_green
    ci_green --> approved
    approved --> auto_merging
    auto_merging --> merged
    merged --> deployed

    ci_running --> ci_red
    ci_red -->|autofix| ci_running

    ci_green --> has_comments
    has_comments --> approved
    has_comments --> changes_requested
    changes_requested --> ci_running

    merged --> closed

    style draft fill:#f5f5f5,stroke:#9e9e9e
    style ci_running fill:#fff3e0,stroke:#e65100
    style ci_green fill:#e8f5e9,stroke:#2e7d32
    style approved fill:#e8f5e9,stroke:#2e7d32
    style auto_merging fill:#e8f5e9,stroke:#2e7d32
    style merged fill:#eeeeee,stroke:#757575
    style deployed fill:#e8f5e9,stroke:#1b5e20
    style ci_red fill:#ffebee,stroke:#c62828
    style has_comments fill:#e3f2fd,stroke:#1565c0
    style changes_requested fill:#fce4ec,stroke:#c62828
    style closed fill:#f5f5f5,stroke:#9e9e9e
