---
title: Autolearn — Boucle auto-améliorante post-échec
---
flowchart TB
    failure([Skill échoue\nclaude_error / no_diff / no_pr_description])

    failure --> judge[Judge.evaluate\nlog digest → claude -p\n→ verdict JSON]

    judge --> record[(record_cycle\nverdict + root_cause\n+ suggested_patch)]
    record --> retryable{"retryable?\nretry_count < 3\nand skill_defect or infra_error"}

    retryable -->|non| skip_reason{verdict?}
    skip_reason -->|item_hard| skip_hard([skip — item_hard])
    skip_reason -->|context_limit| skip_ctx([skip — context_limit])
    skip_reason -->|exhausted| skip_exhaust([skip — autolearn_exhausted])

    retryable -->|oui| defect{skill_defect\nand confidence ge 0.5?}

    defect -->|non| reset_pending[reset to pending\nbranch: nil]

    defect -->|oui| cap{pitfalls count\n< 5?}
    cap -->|non| patch_cap([STOP — needs\nkaizen synth])
    cap -->|oui| patch[apply_skill_patch\nappend patterns.md\ngit commit dans night-shift]
    patch --> reset_pending

    reset_pending --> inc[retry_count += 1]
    inc --> next_cycle([Reconciler relance\nau prochain cycle 120s])

    style failure fill:#ffebee,stroke:#c62828
    style judge fill:#fff3e0,stroke:#e65100
    style record fill:#e0e0e0,stroke:#757575
    style patch fill:#e8f5e9,stroke:#2e7d32
    style patch_cap fill:#ffebee,stroke:#c62828
    style next_cycle fill:#f3e5f5,stroke:#6a1b9a
    style skip_hard fill:#eeeeee,stroke:#757575
    style skip_ctx fill:#eeeeee,stroke:#757575
    style skip_exhaust fill:#eeeeee,stroke:#757575
