title: Skill Runner — Execution d un item
---
flowchart LR
    launch([Reconciler\nclaim_next])
    worktree([git worktree add\nauto/skill/slug])
    pid([write PID\nzombie detection])
    prompt([build prompt\n/skill item])
    tools([extract\nallowed-tools\nfrom SKILL.md])
    claude([claude -p\nmax-turns 200\nstream-json log])
    check_result{succes +\nnew commits?}

    launch --> worktree --> pid --> prompt
    prompt --> tools --> claude --> check_result

    check_desc{pr-description.md\nexists?}
    push([git push\n-u origin branch])
    pr_create([gh pr create\ntitle + body])
    pr_open([pr_open])

    check_result -->|oui| check_desc
    check_desc -->|oui| push --> pr_create --> pr_open

    check_desc -->|non| failure
    check_result -->|rate limited| backoff([pending\nretry after 30min])
    check_result -->|claude error\nno diff| failure([failure\nvoir autolearn])

